# K-9 LLM Router — environment config
# Copy to .env and fill in values. Never commit .env.

# ── ROUTER MODE ─────────────────────────────────────────────────────────────
# "local"  — Ollama/VLLM only. No cloud. Air-gapped safe.
# "cloud"  — Cloud only (Anthropic). No local models needed.
# "hybrid" — Local first, cloud fallback if local is down. (DEFAULT)
ROUTER_MODE=hybrid

# ── LOCAL INFERENCE ──────────────────────────────────────────────────────────
# Ollama running on WSL2 or Mac Mini via Tailscale
LOCAL_MODEL_URL=http://localhost:11434

# If Ollama is on a remote Mac Mini via Tailscale (replace with actual Tailscale IP):
# LOCAL_MODEL_URL=http://100.x.x.x:11434

# ── CLOUD FALLBACK ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── NETWORKING ───────────────────────────────────────────────────────────────
ROUTER_PORT=8765
HEADSCALE_URL=http://localhost:8080

# ── ORBITRON INTEGRATION ─────────────────────────────────────────────────────
# Supabase backend for Orbitron platform-sync event bus
ORBITRON_URL=https://ziqenqqgnqxqrazmjohs.supabase.co
ORBITRON_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InppcWVucXFnbnF4cXJhem1qb2hzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTY3MjM1MjMsImV4cCI6MjA3MjI5OTUyM30.QD-EQ0FIuknfn8kS7-pyBBqvYGGd5L6JCMjbfdub6IQ
# ORBITRON_AUTH_TOKEN — set this to your JWT bearer token (from browser session or node API key)
ORBITRON_AUTH_TOKEN=

# Paymaster (Economic Agent)
K9_PAYMASTER_URL=http://localhost:9002
K9_PAYMASTER_ENABLE=true
K9_DAILY_BUDGET_USD=10.00
K9_TASK_CAP_USD=1.00
K9_AUTO_APPROVE_UNDER=0.10
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=
MOONPAY_SANDBOX=true

# MCP Manager (Tool Registry)
K9_MCP_MANAGER_URL=http://localhost:3030

# n8n Webhook Bridge
N8N_WEBHOOK_SECRET=           # Set to match n8n HTTP node Authorization header
K9_ORCHESTRATOR_URL=http://localhost:8744

# k9-orchestrator
K9_ORCHESTRATOR_HOST=0.0.0.0
K9_ORCHESTRATOR_PORT=8744

# Sprint 4 — Redis Task Queue
REDIS_URL=redis://localhost:6379
TASK_RESULT_TTL_S=3600

# ── FedWhisperer ──────────────────────────────────────────────────────────────
FED_WHISPERER_URL=http://localhost:8767        # FedWhisperer service endpoint
FED_CONTEXT_CACHE_TTL=300                      # seconds to cache FRED data
FED_FUNDS_RATE_ESTIMATE=0.053                  # fallback rate if FRED unavailable

# ── LLM / Cloud ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=                                # OpenAI GPT-4o fallback
LLM_ROUTER_URL=http://localhost:8765           # k9-llm-router base URL (for internal callers)

# ── Supabase (direct access) ──────────────────────────────────────────────────
SUPABASE_URL=https://ziqenqqgnqxqrazmjohs.supabase.co

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_URL=http://localhost:5678                  # n8n workflow engine endpoint

# ── PackAI Node ───────────────────────────────────────────────────────────────
NODE_PORT=8766                                 # packai-node listen port

# ── Paymaster (extended) ──────────────────────────────────────────────────────
K9_PAYMENT_CAP_USD=1.00                        # per-payment hard cap (MoonPay rail)
K9_AUTONOMY_LEVEL=2                            # 1=advisory-only, 2=auto<threshold, 3=full-auto
K9_LEDGER_PATH=./k9_ledger.jsonl               # local append-only ledger path

# ── MoonPay (extended) ────────────────────────────────────────────────────────
MOONPAY_BASE_URL=https://api.moonpay.com       # override for sandbox: https://api.moonpay.com

# ── Tailscale / Headscale ─────────────────────────────────────────────────────
HEADSCALE_API_KEY=                             # Headscale admin API key (k9-device-hub)

# -- Celery worker (Sprint 4b) -------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0     # Celery broker (matches REDIS_URL)
CELERY_RESULT_BACKEND=redis://localhost:6379/0 # Celery result backend
CELERY_CONCURRENCY=4                           # worker slots (run_quant is CPU-light)
